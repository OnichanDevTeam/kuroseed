{
  "name": "kuroseed",
  "version": "1.0.5",
  "description": "Local anime auto-downloader with Nyaa.si RSS and built-in torrent engine",
  "author": "OnichanDevTeam",
  "main": "electron-main.js",
  "scripts": {
    "start": "node index.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder install-app-deps && electron-builder",
    "electron:build:win": "electron-builder install-app-deps && electron-builder --win",
    "electron:build:mac": "electron-builder install-app-deps && electron-builder --mac",
    "electron:icons": "node scripts/generate-icons.js",
    "postinstall": "electron-builder install-app-deps",
    "bundle:webtorrent": "node scripts/patch-bundle.js"
  },
  "dependencies": {
    "better-sqlite3": "11.7.0",
    "express": "4.21.0",
    "fast-xml-parser": "4.5.0",
    "node-cron": "3.0.3",
    "webtorrent": "2.8.5"
  },
  "build": {
    "appId": "com.onichandev.kuroseed",
    "productName": "KuroSeed",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon-256.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "KuroSeed.${version}.exe"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "artifactName": "KuroSeed-${version}-${arch}.dmg"
    }
  },
  "devDependencies": {
    "electron": "33.0.0",
    "electron-builder": "25.0.0",
    "esbuild": "^0.28.0",
    "rcedit": "5.0.2",
    "sharp": "0.33.5"
  }
}
